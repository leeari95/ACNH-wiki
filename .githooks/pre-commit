#!/usr/bin/env bash
# ============================================================================
# Pre-commit hook — ACNH-wiki
# ============================================================================
#
# Runs architecture and pattern validations before each commit.
# To bypass this hook in exceptional cases, use:
#
#   git commit --no-verify
#
# ============================================================================

set -euo pipefail

echo "==> Running pre-commit validations..."
echo ""

if make validate; then
    echo ""
    echo "==> All validations passed. Proceeding with commit."
else
    echo ""
    echo "==> Validation failed. Commit blocked."
    echo "    Fix the issues above, then try again."
    echo "    To bypass this check: git commit --no-verify"
    exit 1
fi

# ----------------------------------------------------------------------------
# Check: Structural change without docs update
# ----------------------------------------------------------------------------
# If Presentation-layer structural files are modified but no docs/ files are
# staged, print a warning to remind the developer to update documentation.
# This is advisory only — it does NOT block the commit.
# ----------------------------------------------------------------------------

STAGED_FILES=$(git diff --cached --name-only)

HAS_STRUCTURAL_CHANGE=false
HAS_DOCS_UPDATE=false

while IFS= read -r file; do
    if echo "$file" | grep -qE 'Presentation/.*(Reactor|Coordinator|ViewController)\.swift$'; then
        HAS_STRUCTURAL_CHANGE=true
    fi
    if echo "$file" | grep -qE '^docs/'; then
        HAS_DOCS_UPDATE=true
    fi
done <<< "$STAGED_FILES"

if [ "$HAS_STRUCTURAL_CHANGE" = true ] && [ "$HAS_DOCS_UPDATE" = false ]; then
    echo ""
    echo "⚠️ Presentation 구조 파일이 변경되었지만 docs/가 업데이트되지 않았습니다."
    echo ""
fi

exit 0
